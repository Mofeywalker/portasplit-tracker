# Copy this file to `.env` (gitignored) and fill in your values.
# Used by docker-compose.yml for variable substitution into the app container.

TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token
# Optional startup SEED for the recipient list (one id, or several comma-separated). Merged into the
# DB as confirmed recipients on boot. At runtime people opt in via the bot (/start + confirm) and out
# via /stop - you can leave this empty and add everyone through the bot instead.
TELEGRAM_CHAT_ID=987654321,123456789

# AES key to encrypt the stored toom Click&Reserve password at rest. Generate one with:
#   openssl rand -base64 32
RESERVE_CRYPTO_KEY=
